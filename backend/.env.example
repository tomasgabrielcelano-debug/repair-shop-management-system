# Copy to .env (gitignored) and fill values.
# Used by docker-compose.prod.yml

# PostgreSQL connection string for the API
CONNECTIONSTRINGS__REPAIRSHOPDB=Host=postgres;Port=5432;Database=repairshop;Username=postgres;Password=CHANGE_ME

# JWT signing key (>= 32 chars recommended)
JWT__KEY=CHANGE_ME_SUPER_SECRET_KEY
JWT__ISSUER=RepairShop
JWT__AUDIENCE=RepairShop

# CORS allowed origin(s) for the frontend
CORS_ALLOWED_ORIGIN_0=https://your-frontend-domain.example
# CORS_ALLOWED_ORIGIN_1=https://another-domain.example

# Allowed hosts for Host filtering (use your API domain)
ALLOWED_HOSTS=api.your-domain.example
